APP_NAME="Talki API"
DEBUG=True

# Supabase Postgres – Settings > Database > Connection string > URI (mode: Session)
DATABASE_URL="postgresql+asyncpg://postgres.<project-ref>:<password>@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres"

# Supabase – Settings > API
SUPABASE_URL="https://<project-ref>.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="eyJ..."   # service_role key (KHÔNG commit key này!)
SUPABASE_JWT_SECRET="..."            # Settings > API > JWT Secret

# Google Gemini – https://aistudio.google.com/app/apikey
GEMINI_API_KEY="AIza..."
GEMINI_MODEL="gemini-2.5-flash"

# Google Cloud STT/TTS — đường dẫn file service account JSON (để trống nếu chưa dùng)
GOOGLE_CLOUD_CREDENTIALS_JSON=""

# Cloudinary – https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
CLOUDINARY_UPLOAD_FOLDER="talki-lessons"

# Audio storage (Supabase Storage bucket)
AUDIO_BUCKET="lesson-audio"
