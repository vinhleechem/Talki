# Copy thành .env (dev) hoặc .env.production (máy chủ deploy). Không commit file có giá trị thật.
# Docker prod: truyền VITE_* khi build, ví dụ:
#   docker compose --env-file talki-backend/.env.production --env-file frontend/.env.production -f docker-compose.prod.yml build
# Supabase – lấy tại: https://supabase.com/dashboard/project/<project-ref>/settings/api
VITE_SUPABASE_URL="https://<project-ref>.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="eyJ..."   # anon/public key
VITE_SUPABASE_PROJECT_ID="<project-ref>"

# Backend FastAPI (khi chạy local)
VITE_API_URL="http://localhost:8000/api/v1"
