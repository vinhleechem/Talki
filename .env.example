# Root-level docker-compose variables (copy to .env and edit for your machine)
# Nếu không set GOOGLE_CREDENTIALS_HOST_PATH, docker-compose.yml dùng mặc định ./secrets/google-credentials.json
# WSL/Linux path examples:
#   /mnt/e/keys/talki-490106-da64ab764488.json
#   /mnt/d/keys/talki-490106-da64ab764488.json
# Windows PowerShell Docker path examples:
#   E:/keys/talki-490106-da64ab764488.json
#   D:/keys/talki-490106-da64ab764488.json
GOOGLE_CREDENTIALS_HOST_PATH=/mnt/e/keys/talki-490106-da64ab764488.json
